# Copy this file to .env.local and fill in the values from your Supabase
# project dashboard (Project Settings > API).
#
# The NEXT_PUBLIC_ prefix is required so these values are readable in the
# browser — this is safe because the anon key is designed to be public and
# is protected by your Supabase Row Level Security (RLS) policies.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
